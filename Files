<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RTE Index - Revenue Through Efficiency</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .bg-navy { background-color: #0A2540; }
    .text-navy { color: #0A2540; }
    .text-teal { color: #00BFA5; }
    .bg-teal { background-color: #00BFA5; }
    .bg-teal-light { background-color: #00d4b8; }
    .bg-gray-50 { background-color: #F6F8FB; }
  </style>
</head>
<body class="antialiased">
  <!-- Hero -->
  <section class="min-h-screen bg-navy flex items-center justify-center px-6 py-20">
    <div class="text-center max-w-4xl">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
        Stop Losing <span class="text-teal">$10k–$30k</span> Monthly to Hidden Revenue Leaks
      </h1>
      <p class="text-lg text-white/80 mb-8">
        Recover 15–25% more revenue with our free RTE diagnostic — proven for independent auto repair shops.
      </p>
      <a href="#calculator" class="inline-flex items-center gap-2 px-8 py-4 bg-teal text-navy font-semibold rounded-xl hover:bg-teal-light transition-colors">
        Run Free Audit
      </a>
    </div>
  </section>

  <!-- Calculator -->
  <section id="calculator" class="py-20 bg-gray-50 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-navy mb-8">Quick ROI Calculator</h2>
      <div class="bg-white p-8 rounded-2xl shadow-lg">
        <input type="number" placeholder="Annual Revenue" class="w-full p-4 border rounded-xl mb-4">
        <input type="number" placeholder="Number of Bays" class="w-full p-4 border rounded-xl mb-4">
        <input type="number" placeholder="No-Show Rate %" class="w-full p-4 border rounded-xl mb-6">
        <button class="w-full py-4 bg-teal text-navy font-semibold rounded-xl hover:bg-teal-light">
          Calculate My Leakage
        </button>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section id="problem" class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold text-teal uppercase mb-4">The Invisible Leakage</p>
      <h2 class="text-3xl md:text-4xl font-bold text-navy mb-6">
        Your shop management system shows what happened. RTE Index reveals what's missing.
      </h2>
      <div class="bg-white p-8 rounded-2xl shadow-lg border-l-4 border-teal">
        <p class="text-sm text-gray-500 uppercase mb-2">Typical Monthly Leakage</p>
        <p class="text-5xl font-extrabold text-teal mb-2">$10k–$30k</p>
        <p class="text-navy font-medium">Recoverable through simple scheduling + confirmation fixes</p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="py-20 bg-gray-50 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-navy mb-12">How the Audit Works</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-2xl shadow">
          <div class="w-10 h-10 bg-teal rounded-full flex items-center justify-center text-navy font-bold mb-4 mx-auto">1</div>
          <h3 class="font-bold text-navy mb-2">Share a quick export</h3>
          <p class="text-gray-500 text-sm">Jobs + schedule CSV or connect your shop management system</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow">
          <div class="w-10 h-10 bg-teal rounded-full flex items-center justify-center text-navy font-bold mb-4 mx-auto">2</div>
          <h3 class="font-bold text-navy mb-2">Expert analysis</h3>
          <p class="text-gray-500 text-sm">Our senior analysts review your customer journey</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow">
          <div class="w-10 h-10 bg-teal rounded-full flex items-center justify-center text-navy font-bold mb-4 mx-auto">3</div>
          <h3 class="font-bold text-navy mb-2">Get your report</h3>
          <p class="text-gray-500 text-sm">RTE Index score and prioritized fix list in 60 seconds</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sample Report -->
  <section id="sample-report" class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="bg-white p-8 rounded-2xl shadow-lg">
        <div class="flex justify-between items-start mb-8 pb-8 border-b">
          <div>
            <p class="text-xs text-gray-500 uppercase">Sample Report</p>
            <h2 class="text-xl font-bold text-navy">Your RTE Index Score</h2>
          </div>
          <div class="text-right">
            <p class="text-5xl font-extrabold text-navy">58<span class="text-2xl text-gray-400">/100</span></p>
            <p class="text-xs text-gray-500">Benchmark: 60–75 | Top 10%: 90+</p>
          </div>
        </div>
        <div class="space-y-4">
          <div class="flex justify-between py-3 border-b">
            <span class="text-gray-500">Monthly leakage</span>
            <span class="text-xl font-bold text-navy">$14,200</span>
          </div>
          <div class="flex justify-between py-3 border-b">
            <span class="text-gray-500">Annual leakage</span>
            <span class="text-xl font-bold text-navy">$170,400</span>
          </div>
          <div class="flex justify-between py-3">
            <span class="text-gray-500">Recoverable (55%)</span>
            <span class="text-2xl font-extrabold text-teal">$93,720</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section id="typical-results" class="py-20 bg-gray-50 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-navy mb-12">Typical Results</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-2xl shadow">
          <p class="text-sm text-gray-500 mb-2">Multi-Location Service Center</p>
          <p class="text-3xl font-extrabold text-teal mb-2">$342k</p>
          <p class="text-sm text-gray-500 mb-4">annual recovery</p>
          <div class="flex justify-center gap-2 mb-4">
            <span class="text-xl font-bold text-gray-400">48</span>
            <span class="text-teal">→</span>
            <span class="text-xl font-bold text-teal">79</span>
          </div>
          <p class="text-xs text-gray-500">"RTE uncovered leaks we missed—game-changer!"</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow">
          <p class="text-sm text-gray-500 mb-2">Independent Shop</p>
          <p class="text-3xl font-extrabold text-teal mb-2">$12k/mo</p>
          <p class="text-sm text-gray-500 mb-4">monthly recovery</p>
          <div class="flex justify-center gap-2 mb-4">
            <span class="text-xl font-bold text-gray-400">51</span>
            <span class="text-teal">→</span>
            <span class="text-xl font-bold text-teal">74</span>
          </div>
          <p class="text-xs text-gray-500">"Boosted parts margins by 8%."</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow">
          <p class="text-sm text-gray-500 mb-2">Specialty Shop</p>
          <p class="text-3xl font-extrabold text-teal mb-2">24%</p>
          <p class="text-sm text-gray-500 mb-4">efficiency gain</p>
          <div class="flex justify-center gap-2 mb-4">
            <span class="text-xl font-bold text-gray-400">63</span>
            <span class="text-teal">→</span>
            <span class="text-xl font-bold text-teal">86</span>
          </div>
          <p class="text-xs text-gray-500">"Recovered ADAS revenue we were turning away."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Engagement -->
  <section id="engagement" class="py-20 bg-navy px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-12">Engagement Options</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white p-8 rounded-2xl">
          <h3 class="text-xl font-bold text-navy mb-2">Free Diagnostic</h3>
          <p class="text-5xl font-extrabold text-teal mb-6">$0</p>
          <ul class="text-left space-y-2 mb-6 text-gray-600 text-sm">
            <li>✓ RTE Index Score (0-100)</li>
            <li>✓ Exact monthly leakage</li>
            <li>✓ Top 3 friction points</li>
            <li>✓ Prioritized roadmap</li>
          </ul>
          <button class="w-full py-3 border-2 border-navy text-navy font-semibold rounded-xl">Run Free Audit</button>
        </div>
        <div class="bg-white p-8 rounded-2xl border-2 border-teal relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-teal text-navy text-xs font-bold rounded-full">RECOMMENDED</div>
          <h3 class="text-xl font-bold text-navy mb-2">RTE Advisory</h3>
          <p class="text-4xl font-extrabold text-teal mb-1">25%</p>
          <p class="text-gray-500 mb-6">of verified recovery</p>
          <ul class="text-left space-y-2 mb-6 text-gray-600 text-sm">
            <li>✓ 6-month engagement</li>
            <li>✓ Implementation support</li>
            <li>✓ Weekly check-ins</li>
            <li>✓ Recovery guarantee</li>
          </ul>
          <button class="w-full py-3 bg-teal text-navy font-semibold rounded-xl">Apply for Advisory</button>
        </div>
      </div>
      <p class="text-white/60 mt-8 text-sm">Limited to 8–10 shops per quarter</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 bg-navy border-t border-white/10 px-6">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-1">
        <span class="text-xl font-bold text-white">RTE Index</span>
        <span class="text-teal">.</span>
      </div>
      <p class="text-white/50 text-sm">© 2026 RTE Index. Revenue Through Efficiency.</p>
    </div>
  </footer>
</body>
</html>
